PORT=5001
MONGODB_URI=mongodb://localhost:27017/dsa-revision-tracker
JWT_SECRET=change-this-to-a-long-random-string

# --- Email Alerts (configured entirely via .env) ---
# Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.sender@gmail.com
SMTP_PASS=your-16-char-app-password

# Recipient email for revision alerts
DEFAULT_ALERT_EMAIL=your.recipient@gmail.com

# Set to false to disable alerts without removing SMTP config
ALERTS_ENABLED=true

# Cron schedule (default: 8:00 AM daily). Format: minute hour day month weekday
ALERT_CRON_SCHEDULE=0 8 * * *
